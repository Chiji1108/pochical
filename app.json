{
  "expo": {
    "name": "ポチカレ",
    "slug": "pochical",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pochical",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "tech.chiji.pochical"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "tech.chiji.pochical"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-mc-emoji-picker-fork",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ebebec",
          "image": "./assets/images/transparent.png",
          "imageWidth": 160
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "シフトを端末カレンダーに書き出すためにカレンダーを使用します。"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "招待QRコードを読み取るためにカメラを使用します。"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "書き出したシフト画像を写真ライブラリに保存するために使用します。"
        }
      ],
      "expo-sharing",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c8168874-1030-4219-b585-b95c9b91c2f1"
      }
    }
  }
}
